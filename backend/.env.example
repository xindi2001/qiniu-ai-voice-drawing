# DeepSeek API Key (optional — omit for mock mode)
# Variable name MUST be DEEPSEEK_API_KEY (not EK_API_KEY or other names).
# IntelliJ IDEA: Run → Edit Configurations → Environment variables
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Aliyun ASR (optional — omit to fall back to browser Web Speech API)
# Get AppKey from Aliyun Intelligent Speech Interaction console:
# https://nls-portal.console.aliyun.com/
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
ALIYUN_ASR_APP_KEY=your_nls_app_key
